---
import type { BreadcrumbItem } from "../lib/structuredData";

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8 text-sm text-slate-500">
  <ol class="flex flex-wrap items-center gap-2">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {index > 0 && <span aria-hidden="true">/</span>}
          {index === items.length - 1 ? (
            <span aria-current="page" class="text-slate-700">{item.name}</span>
          ) : (
            <a href={item.url} class="hover:text-clinical-700">{item.name}</a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
